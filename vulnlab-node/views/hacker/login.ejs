<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Hacker Mode | Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container" style="max-width: 500px;">
    <div class="glass-panel" style="border-top: 4px solid var(--accent-red);">
      <h2 style="color: var(--accent-red); margin-bottom: 0.5rem;">🔴 Level 1: System Access</h2>
      <p>Enter the demonstration portal. Valid user: <span class="code-font" style="color:white;">user</span> / <span class="code-font" style="color:white;">123</span></p>
      
      <% if(error) { %>
        <div style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-red); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; color: #fca5a5;">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/hacker/login">
        <div class="form-group">
          <label>Username</label>
          <input type="text" name="username" placeholder="Target username..." required>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-hacker">Bypass Authorization</button>
      </form>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/" style="color: var(--text-muted); text-decoration: none;">← Abort & Return to Lobby</a>
      </div>
    </div>
  </div>
</body>
</html>
