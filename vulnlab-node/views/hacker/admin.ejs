<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Hacker Mode | ROOT ADMIN</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background-color: #31080d; background-image: none; }
  </style>
</head>
<body>
  <div class="container">
    <div class="glass-panel" style="border-color: var(--accent-red); box-shadow: 0 0 40px rgba(239, 68, 68, 0.2);">
      <div style="text-align: center; margin-bottom: 2rem;">
        <h1 style="color: var(--accent-red); background: none; -webkit-text-fill-color: initial;">⚠️ CLASSIFIED ADMIN PANEL ⚠️</h1>
        <p style="color: #fca5a5;">You have successfully bypassed authorization controls.</p>
        <span class="badge badge-red" style="font-size: 1rem;">ACCESS GRANTED</span>
      </div>

      <h3>Global User Registry</h3>
      <ul class="admin-list" style="border: 1px solid var(--accent-red);">
        <li style="border-bottom: 1px solid rgba(239, 68, 68, 0.3); padding: 0.5rem 1rem; color: #fca5a5; font-weight: bold;">
          <span>USERNAME</span>
          <span>SYSTEM ROLE</span>
        </li>
      <% for(let u in users) { %>
        <li style="padding: 1rem;">
          <span style="font-size: 1.1rem; color: white;"><%= u %></span>
          <span class="code-font" style="color: var(--accent-yellow);"><%= users[u].role %></span>
        </li>
      <% } %>
      </ul>

      <div style="margin-top: 3rem; text-align: center;">
        <a href="/hacker/dashboard" class="btn" style="background: rgba(255,255,255,0.1);">Back to Safety</a>
      </div>
    </div>
  </div>
</body>
</html>
