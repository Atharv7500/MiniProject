<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mission 03 | Forgot Password</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="top-nav" style="border-bottom-color: var(--accent-cyan);">
    <h3 style="margin:0; color: var(--accent-cyan);">🔴 Mission 03 — Password Reset Exploit</h3>
    <div>
      <a href="/resetexploit/inbox" class="btn btn-cyan btn-sm" style="margin-right:0.5rem;">📬 View Inbox</a>
      <a href="/" class="btn btn-outline btn-sm">← Hub</a>
    </div>
  </nav>

  <div class="container" style="margin-top: 5rem; max-width: 550px;">
    <div class="glass-panel" style="border-top: 4px solid var(--accent-cyan);">
      <span class="badge badge-cyan">VULNERABLE</span>
      <h2 style="color: var(--accent-cyan);">🔑 Forgot Password</h2>
      <p>Enter your email to receive a password reset link.</p>

      <% if (!sent) { %>
        <form method="POST" action="/resetexploit/forgot">
          <div class="form-group">
            <label>Email Address</label>
            <input type="text" name="email" placeholder="admin@techcorp.com" required value="admin@techcorp.com">
          </div>
          <button type="submit" class="btn btn-cyan">Send Reset Link</button>
        </form>
      <% } else { %>
        <div class="alert alert-success">
          ✉️ Reset link sent to <strong><%= email %></strong>
        </div>

        <div class="email-link-vuln">
          <div style="font-size:0.75rem; color:#ef4444; margin-bottom:0.5rem;">⚠️ VULNERABLE RESET LINK:</div>
          <a href="<%= link %>"><%= link %></a>
        </div>

        <div style="background:rgba(0,0,0,0.2); padding:1rem; border-radius:8px; margin-top:1rem; border:1px solid rgba(6,182,212,0.2);">
          <p style="font-size:0.85rem; margin:0; color: var(--accent-cyan);">💡 <strong>The Exploit:</strong> Notice the URL contains <span class="code-font" style="color:white;">?user=admin</span> — no secret token! An attacker can simply change the username in the URL to reset anyone's password.</p>
        </div>

        <div style="margin-top:1.5rem; display:flex; gap:0.5rem;">
          <a href="<%= link %>" class="btn btn-hacker">Reset Admin Password →</a>
          <a href="/resetexploit/inbox" class="btn btn-cyan">📬 View Inbox</a>
        </div>
      <% } %>

      <div style="text-align:center; margin-top:2rem;">
        <a href="/" style="color:var(--text-muted); text-decoration:none;">← Back to Hub</a>
      </div>
    </div>
  </div>
</body>
</html>
