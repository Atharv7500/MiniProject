<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mission 03 | Reset Password</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="top-nav" style="border-bottom-color: var(--accent-red);">
    <h3 style="margin:0; color: var(--accent-red);">⚠️ Password Reset — VULNERABLE</h3>
    <a href="/" class="btn btn-outline btn-sm">← Hub</a>
  </nav>

  <div class="container" style="margin-top: 5rem; max-width: 550px;">
    <div class="glass-panel" style="border-top: 4px solid var(--accent-red);">
      <span class="badge badge-red">EXPLOITABLE</span>
      <h2 style="color: var(--accent-red);">🔑 Reset Password for: <span class="code-font"><%= username %></span></h2>

      <% if (error) { %>
        <div class="alert alert-danger">❌ <%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-danger" style="text-align:center;">
          <div style="font-size:2rem; margin-bottom:0.5rem;">💀</div>
          <strong>Account Hijacked!</strong><br>
          <span><%= success %></span>
        </div>
        <div style="background:rgba(0,0,0,0.2); padding:1rem; border-radius:8px; border:1px solid rgba(239,68,68,0.2);">
          <p style="font-size:0.85rem; margin:0; color:#fca5a5;">
            🎯 <strong>What happened:</strong> The reset endpoint blindly trusted the <span class="code-font" style="color:white;">?user=</span> parameter. No token, no email verification, no identity check. Anyone who knows the URL pattern can reset any account.
          </p>
        </div>
      <% } else { %>
        <div style="background:rgba(239,68,68,0.1); padding:0.75rem; border-radius:6px; margin-bottom:1.5rem; font-size:0.85rem; color:#fca5a5; font-family:'Fira Code', monospace;">
          URL: /resetexploit/reset?user=<strong><%= username %></strong>
          <br>Token: <span style="color:var(--accent-red);">NONE ❌</span>
        </div>

        <form method="POST" action="/resetexploit/reset">
          <input type="hidden" name="username" value="<%= username %>">
          <div class="form-group">
            <label>New Password</label>
            <input type="text" name="newPassword" placeholder="Enter new password..." required value="hacked123">
          </div>
          <button type="submit" class="btn btn-hacker">💀 Hijack Account</button>
        </form>
      <% } %>

      <div style="text-align:center; margin-top:2rem;">
        <a href="/resetexploit/forgot" style="color:var(--text-muted); text-decoration:none;">← Try Another Reset</a>
      </div>
    </div>
  </div>
</body>
</html>
