<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mission 03 | Secure Forgot Password</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="top-nav" style="border-bottom-color: var(--accent-green);">
    <h3 style="margin:0; color: var(--accent-green);">🟢 Mission 03 — Secure Reset</h3>
    <a href="/" class="btn btn-outline btn-sm">← Hub</a>
  </nav>

  <div class="container" style="margin-top: 5rem; max-width: 550px;">
    <div class="glass-panel" style="border-top: 4px solid var(--accent-green);">
      <span class="badge badge-green">SECURED</span>
      <h2 style="color: var(--accent-green);">🔑 Secure Password Reset</h2>
      <p>Token-based reset with expiry and one-time use.</p>

      <% if (!sent) { %>
        <form method="POST" action="/resetexploit/secure/forgot">
          <div class="form-group">
            <label>Email Address</label>
            <input type="text" name="email" placeholder="admin@techcorp.com" required value="admin@techcorp.com" style="border-color:rgba(16,185,129,0.3);">
          </div>
          <button type="submit" class="btn btn-secure">Send Secure Reset Link</button>
        </form>
      <% } else { %>
        <div class="alert alert-success">✓ <%= info %></div>

        <% if (typeof token !== 'undefined' && token) { %>
          <div style="background:rgba(16,185,129,0.1); padding:1rem; border-radius:8px; border:1px solid rgba(16,185,129,0.3); margin-bottom:1rem;">
            <div style="font-size:0.75rem; color:var(--accent-green); margin-bottom:0.5rem;">🔒 SECURE RESET LINK (demo visibility):</div>
            <div class="code-font" style="font-size:0.8rem; word-break:break-all; color:white;"><a href="<%= link %>" style="color:var(--accent-green);"><%= link %></a></div>
            <div style="margin-top:0.75rem; font-size:0.75rem; color:#94a3b8;">
              Token: <span class="code-font" style="color:white;"><%= token %></span><br>
              Expires: 15 minutes | One-time use only
            </div>
          </div>

          <div style="background:rgba(0,0,0,0.2); padding:1rem; border-radius:8px; border:1px solid rgba(16,185,129,0.2);">
            <p style="font-size:0.85rem; margin:0; color:var(--accent-green);">✓ <strong>Why this is secure:</strong> The link contains a random UUID token, not a username. It expires in 15 min and can only be used once. Guessing the token is computationally infeasible.</p>
          </div>

          <div style="margin-top:1.5rem;">
            <a href="<%= link %>" class="btn btn-secure">Use Secure Reset Link →</a>
          </div>
        <% } %>
      <% } %>

      <div style="text-align:center; margin-top:2rem;">
        <a href="/" style="color:var(--text-muted); text-decoration:none;">← Back to Hub</a>
      </div>
    </div>
  </div>
</body>
</html>
